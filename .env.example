# ─── AI News Agent Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot Token (required)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram Chat ID (required)
# Send a message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": <YOUR_CHAT_ID>}
TELEGRAM_CHAT_ID=your-chat-id-here

# ─── Optional Settings ──────────────────────────────────────────────

# Tracked companies (comma-separated, overrides defaults)
# TRACKED_COMPANIES=OpenAI,Anthropic,Google DeepMind,Perplexity,xAI,Mistral AI

# Max articles to fetch per feed (default: 50)
# MAX_ARTICLES_PER_FEED=50

# Max articles in the digest (default: 30)
# DIGEST_MAX_ARTICLES=30

# Importance score threshold for 'breaking news' flag (default: 8.0)
# BREAKING_NEWS_THRESHOLD=8.0

# Summary language: "english" or "hindi" (default: english)
# SUMMARY_LANGUAGE=english

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
